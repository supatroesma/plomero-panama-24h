---
export type Props = {
  formName?: string;
};

const { formName = 'contacto' } = Astro.props;
---

<form
  name={formName}
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  class="bg-white border border-[color:var(--color-border-base)] rounded-xl p-5 md:p-6 max-w-xl"
>
  <input type="hidden" name="form-name" value={formName} />
  <p class="hidden">
    <label>No llenar: <input name="bot-field" /></label>
  </p>

  <div class="mb-4">
    <label for="nombre" class="block text-sm font-semibold mb-1.5">Nombre completo</label>
    <input
      type="text"
      id="nombre"
      name="nombre"
      required
      autocomplete="name"
      class="w-full border border-[color:var(--color-border-base)] rounded-lg px-3 py-2.5 text-base focus:outline-none focus:border-[color:var(--color-primary)] focus:ring-2 focus:ring-[color:var(--color-primary-light)]"
    />
  </div>

  <div class="mb-4">
    <label for="telefono" class="block text-sm font-semibold mb-1.5">Teléfono / WhatsApp</label>
    <input
      type="tel"
      id="telefono"
      name="telefono"
      required
      autocomplete="tel"
      placeholder="+507"
      class="w-full border border-[color:var(--color-border-base)] rounded-lg px-3 py-2.5 text-base focus:outline-none focus:border-[color:var(--color-primary)] focus:ring-2 focus:ring-[color:var(--color-primary-light)]"
    />
  </div>

  <div class="mb-5">
    <label for="mensaje" class="block text-sm font-semibold mb-1.5">¿Qué necesitas?</label>
    <textarea
      id="mensaje"
      name="mensaje"
      rows="4"
      required
      class="w-full border border-[color:var(--color-border-base)] rounded-lg px-3 py-2.5 text-base focus:outline-none focus:border-[color:var(--color-primary)] focus:ring-2 focus:ring-[color:var(--color-primary-light)] resize-y"
    ></textarea>
  </div>

  <button
    type="submit"
    class="w-full bg-[color:var(--color-primary)] hover:bg-[color:var(--color-primary-dark)] text-white font-bold py-3 rounded-lg text-base transition-colors"
  >
    Enviar solicitud
  </button>

  <p class="text-xs text-[color:var(--color-text-muted)] mt-3 text-center">
    Te respondemos en menos de 30 minutos vía WhatsApp.
  </p>
</form>
