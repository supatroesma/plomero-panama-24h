---
export type Props = {
  title?: string;
  items?: string[];
};

const {
  title = '¿Por qué confiar en nosotros?',
  items = [
    'Servicio profesional en toda Ciudad de Panamá',
    'Disponible 24 horas, 7 días a la semana',
    'Cotización gratis sin compromiso vía WhatsApp',
    'Cumplimos con normas técnicas locales',
    'Garantía sobre el trabajo realizado',
    'Llegada en 30-60 minutos según la zona',
  ],
} = Astro.props;
---

<section class="bg-[color:var(--color-bg-alt)] py-12 md:py-16">
  <div class="container-site max-w-4xl">
    <h2 class="mb-6 text-center md:text-left">{title}</h2>
    <ul class="grid grid-cols-1 md:grid-cols-2 gap-3 list-none p-0">
      {items.map((item) => (
        <li class="flex items-start gap-3 bg-white border border-[color:var(--color-border-base)] rounded-lg p-4">
          <span class="text-[color:var(--color-success)] text-xl shrink-0" aria-hidden="true">✓</span>
          <span class="text-sm md:text-base">{item}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
