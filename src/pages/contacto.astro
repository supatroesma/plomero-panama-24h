---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadCrumbs from '../components/BreadCrumbs.astro';
import ContactForm from '../components/ContactForm.astro';
import { siteConfig, buildPhoneLink, buildWhatsAppLink } from '../data/site';

const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Contacto', url: '/contacto' },
];

const phoneHref = buildPhoneLink();
const waHref = buildWhatsAppLink();
---

<BaseLayout
  title="Contacto | Plomero Panamá 24h"
  description="Contacta a Plomero Panamá 24h por WhatsApp, teléfono o formulario. Servicio profesional en toda Ciudad de Panamá. Cotización gratis sin compromiso."
  schema={{ type: 'page', breadcrumbs }}
>
  <BreadCrumbs items={breadcrumbs} />

  <section class="container-site py-6 md:py-10">
    <div class="max-w-3xl mb-10">
      <h1 class="mb-4">Contáctanos</h1>
      <p class="text-lg text-[color:var(--color-text-muted)] leading-relaxed">
        Respuesta rápida vía WhatsApp en horario regular. Cotización gratis sin compromiso. Servicio de emergencias disponible — consulta disponibilidad inmediata.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
      <div>
        <h2 class="mb-4">Vías de contacto rápidas</h2>
        <ul class="space-y-3 list-none p-0 mb-8">
          <li>
            <a href={waHref} target="_blank" rel="noopener" class="flex items-center gap-3 bg-[color:var(--color-whatsapp)] hover:bg-[color:var(--color-whatsapp-dark)] text-white p-4 rounded-lg no-underline transition-colors">
              <span class="text-2xl" aria-hidden="true">💬</span>
              <div>
                <strong class="block">WhatsApp</strong>
                <span class="text-sm opacity-90">Respuesta rápida</span>
              </div>
            </a>
          </li>
          <li>
            <a href={phoneHref} class="flex items-center gap-3 bg-[color:var(--color-primary)] hover:bg-[color:var(--color-primary-dark)] text-white p-4 rounded-lg no-underline transition-colors">
              <span class="text-2xl" aria-hidden="true">📞</span>
              <div>
                <strong class="block">{siteConfig.phone}</strong>
                <span class="text-sm opacity-90">Llamada directa 24h</span>
              </div>
            </a>
          </li>
          <li>
            <a href={`mailto:${siteConfig.email}`} class="flex items-center gap-3 bg-white border border-[color:var(--color-border-base)] p-4 rounded-lg no-underline transition-colors hover:border-[color:var(--color-primary)]">
              <span class="text-2xl" aria-hidden="true">✉️</span>
              <div>
                <strong class="block text-[color:var(--color-text-base)]">{siteConfig.email}</strong>
                <span class="text-sm text-[color:var(--color-text-muted)]">Para consultas no urgentes</span>
              </div>
            </a>
          </li>
        </ul>

        <h2 class="mb-3">Información del servicio</h2>
        <dl class="space-y-2 text-base">
          <div>
            <dt class="font-semibold inline">Horario:</dt>
            <dd class="inline text-[color:var(--color-text-muted)]">{siteConfig.hoursText}</dd>
          </div>
          <div>
            <dt class="font-semibold inline">Cobertura:</dt>
            <dd class="inline text-[color:var(--color-text-muted)]">{siteConfig.serviceArea}</dd>
          </div>
          <div>
            <dt class="font-semibold inline">Pagos:</dt>
            <dd class="inline text-[color:var(--color-text-muted)]">Efectivo, tarjeta, transferencia, Yappy</dd>
          </div>
          <div>
            <dt class="font-semibold inline">Cotización:</dt>
            <dd class="inline text-[color:var(--color-text-muted)]">Gratis, sin compromiso</dd>
          </div>
        </dl>
      </div>

      <div>
        <h2 class="mb-4">Formulario de contacto</h2>
        <p class="text-sm text-[color:var(--color-text-muted)] mb-4">
          Si prefieres dejar tus datos por aquí, te llamamos o escribimos por WhatsApp con respuesta rápida.
        </p>
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>
