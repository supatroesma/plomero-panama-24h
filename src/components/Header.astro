---
import { siteConfig, buildPhoneLink } from '../data/site';
import { services } from '../data/services';

const phoneHref = buildPhoneLink();
---

<header class="sticky top-0 z-40 bg-white border-b border-[color:var(--color-border-base)] shadow-sm">
  <div class="container-site flex items-center justify-between py-3 md:py-4">
    <a href="/" class="flex items-center gap-2 no-underline" aria-label={siteConfig.name}>
      <img
        src="/images/logo-icon.png"
        alt=""
        class="h-10 sm:h-12 w-auto"
        width="48"
        height="48"
        loading="eager"
        decoding="async"
      />
      <span class="text-[color:var(--color-primary)] font-extrabold text-base sm:text-lg md:text-xl leading-tight">
        {siteConfig.name}
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm font-medium" aria-label="Navegación principal">
      <a href="/" class="text-[color:var(--color-text-base)] hover:text-[color:var(--color-primary)] no-underline">Inicio</a>
      <div class="relative group">
        <button type="button" class="flex items-center gap-1 text-[color:var(--color-text-base)] hover:text-[color:var(--color-primary)]">
          Servicios
          <span aria-hidden="true">▾</span>
        </button>
        <div class="absolute top-full left-0 hidden group-hover:block group-focus-within:block bg-white border border-[color:var(--color-border-base)] rounded-lg shadow-lg min-w-[260px] py-2">
          <a href="/servicios" class="block px-4 py-2 text-sm font-semibold hover:bg-[color:var(--color-bg-alt)] no-underline">Todos los servicios</a>
          <hr class="my-1 border-[color:var(--color-border-base)]" />
          {services.map((s) => (
            <a href={`/servicios/${s.slug}`} class="block px-4 py-2 text-sm hover:bg-[color:var(--color-bg-alt)] no-underline text-[color:var(--color-text-base)]">{s.shortName}</a>
          ))}
        </div>
      </div>
      <a href="/zonas" class="text-[color:var(--color-text-base)] hover:text-[color:var(--color-primary)] no-underline">Zonas</a>
      <a href="/precios" class="text-[color:var(--color-text-base)] hover:text-[color:var(--color-primary)] no-underline">Precios</a>
      <a href="/blog" class="text-[color:var(--color-text-base)] hover:text-[color:var(--color-primary)] no-underline">Blog</a>
      <a href="/contacto" class="text-[color:var(--color-text-base)] hover:text-[color:var(--color-primary)] no-underline">Contacto</a>
    </nav>

    <a
      href={phoneHref}
      class="inline-flex items-center gap-2 bg-[color:var(--color-primary)] hover:bg-[color:var(--color-primary-dark)] text-white font-semibold rounded-lg px-3 py-2 text-sm md:px-4 md:py-2.5 md:text-base no-underline transition-colors"
      aria-label={`Llamar al ${siteConfig.phone}`}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
        class="shrink-0"
      >
        <path d="M20 15.5c-1.25 0-2.45-.2-3.57-.57a1 1 0 00-1.02.24l-2.2 2.2a15.07 15.07 0 01-6.59-6.58l2.2-2.21a1 1 0 00.25-1.02A11.36 11.36 0 018.5 4a1 1 0 00-1-1H4a1 1 0 00-1 1c0 9.39 7.61 17 17 17a1 1 0 001-1v-3.5a1 1 0 00-1-1z" />
      </svg>
      <span class="hidden md:inline">{siteConfig.phone}</span>
    </a>
  </div>

  <details class="md:hidden border-t border-[color:var(--color-border-base)]">
    <summary class="container-site py-3 text-sm font-semibold cursor-pointer list-none flex items-center justify-between">
      <span>Menú</span>
      <span aria-hidden="true">☰</span>
    </summary>
    <nav class="container-site pb-4 flex flex-col gap-2 text-sm" aria-label="Navegación móvil">
      <a href="/" class="py-1.5 no-underline text-[color:var(--color-text-base)]">Inicio</a>
      <a href="/servicios" class="py-1.5 no-underline text-[color:var(--color-text-base)] font-semibold">Servicios</a>
      {services.map((s) => (
        <a href={`/servicios/${s.slug}`} class="py-1 pl-3 no-underline text-[color:var(--color-text-muted)] text-sm">→ {s.shortName}</a>
      ))}
      <a href="/zonas" class="py-1.5 no-underline text-[color:var(--color-text-base)]">Zonas</a>
      <a href="/precios" class="py-1.5 no-underline text-[color:var(--color-text-base)]">Precios</a>
      <a href="/emergencias-plomeria-panama" class="py-1.5 no-underline text-[color:var(--color-cta)] font-semibold">Emergencias</a>
      <a href="/blog" class="py-1.5 no-underline text-[color:var(--color-text-base)]">Blog</a>
      <a href="/contacto" class="py-1.5 no-underline text-[color:var(--color-text-base)]">Contacto</a>
    </nav>
  </details>
</header>
