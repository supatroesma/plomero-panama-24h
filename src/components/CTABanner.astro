---
import { siteConfig, buildPhoneLink, buildWhatsAppLink } from '../data/site';

export type Props = {
  title?: string;
  subtitle?: string;
  whatsappMessage?: string;
  variant?: 'primary' | 'urgent';
};

const {
  title = '¿Necesitas un plomero ahora?',
  subtitle = 'Cotización gratis vía WhatsApp. Llegamos en 30-60 minutos.',
  whatsappMessage,
  variant = 'primary',
} = Astro.props;

const bgClass =
  variant === 'urgent'
    ? 'bg-[color:var(--color-cta)]'
    : 'bg-[color:var(--color-primary)]';

const phoneHref = buildPhoneLink();
const waHref = buildWhatsAppLink(whatsappMessage);
---

<section class={`${bgClass} text-white`}>
  <div class="container-site py-10 md:py-14">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div>
        <h2 class="text-white mb-2">{title}</h2>
        <p class="text-white/90 text-base md:text-lg">{subtitle}</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 shrink-0">
        <a
          href={waHref}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 bg-[color:var(--color-whatsapp)] hover:bg-[color:var(--color-whatsapp-dark)] text-white font-bold px-5 py-3 rounded-lg no-underline transition-colors"
        >
          💬 WhatsApp
        </a>
        <a
          href={phoneHref}
          class="inline-flex items-center justify-center gap-2 bg-white text-[color:var(--color-primary)] hover:bg-[color:var(--color-bg-alt)] font-bold px-5 py-3 rounded-lg no-underline transition-colors"
        >
          📞 {siteConfig.phone}
        </a>
      </div>
    </div>
  </div>
</section>
